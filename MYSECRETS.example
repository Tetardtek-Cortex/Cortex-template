## brain — core
# Brain API key (optionnel — sans cle = tier free)
# BRAIN_API_KEY=bk_live_your_key_here

## vps
VPS_IP=
VPS_SSH_USER=
VPS_SSH_PORT=22

## gitea (si self-hosted)
GITEA_HOST=
GITEA_SSH_PORT=2222

## mysql — si vous utilisez une DB sur le VPS
MYSQL_ROOT_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

## projets — prefixer par NOM_PROJET_
# MY_SAAS_APP_DB_PASSWORD=
# MY_SAAS_APP_JWT_SECRET=
# MY_SAAS_APP_OAUTH_CLIENT_SECRET=

# MY_GAME_DB_PASSWORD=

# MY_WEBSITE_SMTP_PASSWORD=
